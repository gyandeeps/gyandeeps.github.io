---
import '../styles/landing.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Gyandeep Singh's personal portfolio website and blog." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://gyandeeps.com');
---

<!DOCTYPE html>
<html class="dark" lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Preconnect CDNs -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Fonts & Material Symbols -->
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600&family=Inter:wght@100..900&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600&family=Inter:wght@100..900&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  </noscript>

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:site_name" content="Gyandeep Singh" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:url" content={canonicalURL} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:site" content="@gyandeeps" />
  <meta name="twitter:creator" content="@gyandeeps" />
  
  <!-- Favicons -->
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/images/apple-touch-icon.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/images/favicon-16x16.png" />
  <link rel="shortcut icon" href="/assets/images/favicon.ico" />

  <!-- Global site tag (gtag.js) - Google Analytics -->
  <script is:inline>
    window.addEventListener('load', () => {
      const delayGA = () => {
        setTimeout(() => {
          const script = document.createElement('script');
          script.async = true;
          script.src = "https://www.googletagmanager.com/gtag/js?id=G-REQ0N1JVXY";
          document.head.appendChild(script);

          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-REQ0N1JVXY');
        }, 1000);
      };

      if ('requestIdleCallback' in window) {
        requestIdleCallback(delayGA);
      } else {
        delayGA();
      }
    });
  </script>
</head>
<body class="font-body-md text-on-surface cyber-grid selection:bg-primary selection:text-on-primary relative">
  <!-- Interactive Elements -->
  <div class="fixed pointer-events-none w-[600px] h-[600px] rounded-full opacity-5 bg-primary blur-[120px] top-0 left-0 transition-transform duration-75 z-0" id="cursor-glow"></div>

  <slot />

  <script is:inline>
    // Cursor glow setup
    const glow = document.getElementById('cursor-glow');
    if (glow) {
      window.addEventListener('mousemove', (e) => {
          glow.style.transform = `translate3d(${e.clientX - 300}px, ${e.clientY - 300}px, 0)`;
      });
    }
  </script>
</body>
</html>
