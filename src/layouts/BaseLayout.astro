---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Gyandeep Singh's personal website and blog." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://gyandeeps.com');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <title>{title} - Gyandeep Singh</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={Astro.url.pathname === '/' ? 'website' : 'article'} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={`${title} - Gyandeep Singh`} />
  <meta property="og:description" content={description} />
  <meta property="og:site_name" content="Gyandeep Singh" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:url" content={canonicalURL} />
  <meta name="twitter:title" content={`${title} - Gyandeep Singh`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:site" content="@gyandeeps" />
  <meta name="twitter:creator" content="@gyandeeps" />
  
  <!-- Favicons -->
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/images/apple-touch-icon.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/images/favicon-16x16.png" />
  <link rel="shortcut icon" href="/assets/images/favicon.ico" />
  <!-- Preconnect CDNs -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Fonts -->
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
  </noscript>

  <!-- Global site tag (gtag.js) - Google Analytics -->
  <script is:inline>
    window.addEventListener('load', () => {
      const delayGA = () => {
        setTimeout(() => {
          const script = document.createElement('script');
          script.async = true;
          script.src = "https://www.googletagmanager.com/gtag/js?id=G-REQ0N1JVXY";
          document.head.appendChild(script);

          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-REQ0N1JVXY');
        }, 1000);
      };

      if ('requestIdleCallback' in window) {
        requestIdleCallback(delayGA);
      } else {
        delayGA();
      }
    });
  </script>
</head>
<body>
  
  <div class="scroll-progress" id="scrollProgress"></div>
  <div class="bg-glow-sphere bg-glow-sphere-1"></div>
  <div class="bg-glow-sphere bg-glow-sphere-2"></div>

  <header class="masthead animate-fade-in">
    <div class="nav-container">
      <a href="/" class="site-title">
        <span>Gyandeep Singh</span>
      </a>
      <nav>
        <ul class="nav-links">
          <li><a href="/" class={Astro.url.pathname === '/' ? 'active' : ''}>Home</a></li>
          <li><a href="/about/" class={Astro.url.pathname.startsWith('/about') ? 'active' : ''}>About</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main class="content-wrapper">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-socials">
      <a href="https://github.com/gyandeeps" target="_blank" rel="noopener noreferrer" title="GitHub"><svg class="inline-block" width="1.2em" height="1.2em" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.137 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z" /></svg></a>
      <a href="https://twitter.com/gyandeeps" target="_blank" rel="noopener noreferrer" title="Twitter"><svg class="inline-block" width="1.2em" height="1.2em" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" /></svg></a>
      <a href="https://www.linkedin.com/in/gyandeeps" target="_blank" rel="noopener noreferrer" title="LinkedIn"><svg class="inline-block" width="1.2em" height="1.2em" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" /></svg></a>
      <a href="mailto:gyandeeps@gmail.com" title="Email"><svg class="inline-block" width="1.2em" height="1.2em" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" /><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" /></svg></a>
    </div>
    <p>&copy; {new Date().getFullYear()} Gyandeep Singh. Built with Astro &amp; Vanilla CSS.</p>
  </footer>

  <script is:inline>
    // Scroll Progress Indicator
    window.addEventListener('scroll', () => {
      const winScroll = document.documentElement.scrollTop || document.body.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
      const progressEl = document.getElementById('scrollProgress');
      if (progressEl) {
        progressEl.style.width = scrolled + '%';
      }
    });

    // Mouse tracking for cards
    function setupCardGlows() {
      const cards = document.querySelectorAll('.post-card');
      cards.forEach(card => {
        card.addEventListener('mousemove', e => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          card.style.setProperty('--mouse-x', `${x}px`);
          card.style.setProperty('--mouse-y', `${y}px`);
        });
      });
    }

    // Initialize on load
    window.addEventListener('DOMContentLoaded', setupCardGlows);
  </script>
</body>
</html>
