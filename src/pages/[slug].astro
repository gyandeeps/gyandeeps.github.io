---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Disqus from '../components/Disqus.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => {
    const match = post.id.match(/^(\d{4}-\d{2}-\d{2})-(.+)$/);
    const dateStr = match ? match[1] : '';
    const urlSlug = match ? match[2] : post.id;
    return {
      params: { slug: urlSlug },
      props: { post, dateStr, urlSlug },
    };
  });
}

const { post, dateStr, urlSlug } = Astro.props;
const { Content } = await render(post);

const dateObj = dateStr ? new Date(dateStr) : new Date();
const formattedDate = dateObj.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC'
});
---

<BaseLayout title={post.data.title} description={post.data.excerpt}>
  <article class="animate-fade-in delay-1">
    <div class="back-link-container">
      <a href="/" class="back-link">
        <i class="fas fa-arrow-left"></i> Back to Home
      </a>
    </div>

    <header class="article-header">
      <h1 class="article-title">{post.data.title}</h1>
      <div class="post-meta">
        <time datetime={dateObj.toISOString().split('T')[0]}>{formattedDate}</time>
        {post.data.author && (
          <span>&bull;</span>
          <span>By {post.data.author}</span>
        )}
      </div>
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="tag-list" style="margin-top: 1rem;">
          {post.data.tags.map(tag => (
            <span class="tag-badge">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="article-content animate-fade-in delay-2">
      <Content />
    </div>

    <!-- Disqus Comments Thread -->
    <div class="animate-fade-in delay-3">
      <Disqus slug={urlSlug} title={post.data.title} />
    </div>
  </article>
</BaseLayout>

<style>
  .back-link-container {
    margin-bottom: 2rem;
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s, transform 0.2s;
  }
  .back-link:hover {
    color: var(--color-accent);
    transform: translateX(-4px);
  }
</style>
