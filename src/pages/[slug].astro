---
import { getCollection, render } from 'astro:content';
import PortfolioLayout from '../layouts/PortfolioLayout.astro';
import Disqus from '../components/Disqus.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => {
    const match = post.id.match(/^(\d{4}-\d{2}-\d{2})-(.+)$/);
    const dateStr = match ? match[1] : '';
    const urlSlug = match ? match[2] : post.id;
    return {
      params: { slug: urlSlug },
      props: { post, dateStr, urlSlug },
    };
  });
}

const { post, dateStr, urlSlug } = Astro.props;
const { Content } = await render(post);

const dateObj = dateStr ? new Date(dateStr) : new Date();
const formattedDate = dateObj.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC'
});
---

<PortfolioLayout title={`${post.data.title} - Gyandeep Singh`} description={post.data.excerpt}>
  <Navbar isHome={false} />

  <main class="pt-32 pb-xl px-lg max-w-[900px] mx-auto">
    <!-- Back to Blog Link -->
    <div class="mb-lg animate-fade-in">
      <a href="/#blog" class="inline-flex items-center gap-2 text-primary hover:text-primary-fixed-dim transition-colors font-technical-sm text-technical-sm group">
        <span class="material-symbols-outlined text-sm transition-transform group-hover:-translate-x-1">arrow_back</span>
        Back to Writing
      </a>
    </div>

    <!-- Article Container -->
    <article class="glass-panel p-lg md:p-xl rounded-xl border-primary/20 animate-fade-in delay-1">
      <header class="border-b border-primary/20 pb-lg mb-lg">
        <div class="text-primary font-mono text-[11px] uppercase tracking-widest mb-2">{formattedDate}</div>
        <h1 class="font-display-lg text-3xl md:text-4xl text-white mb-md leading-tight">{post.data.title}</h1>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-xs">
            {post.data.tags.map(tag => (
              <span class="text-[12px] font-mono text-primary/60 px-2 py-0.5 border border-primary/10 rounded uppercase">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <!-- Compiled Markdown Content -->
      <div class="post-content-container prose prose-invert max-w-none mb-xl animate-fade-in delay-2">
        <Content />
      </div>

      <!-- Comments Section -->
      <div class="mt-xl pt-lg border-t border-primary/20 animate-fade-in delay-3">
        <h3 class="font-headline-sm text-lg text-primary uppercase mb-md tracking-wider">Discussion</h3>
        <Disqus slug={urlSlug} title={post.data.title} />
      </div>
    </article>
  </main>

  <Footer isHome={false} />

  <script is:inline>
    // Content fade-in animations using performant transitions and custom curves
    const observerOptions = { threshold: 0.05, rootMargin: '0px 0px -30px 0px' };
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('opacity-100', 'translate-y-0');
                entry.target.classList.remove('opacity-0', 'translate-y-4');
                observer.unobserve(entry.target);
            }
        });
    }, observerOptions);

    document.querySelectorAll('.animate-fade-in').forEach(el => {
        el.classList.add('opacity-0', 'translate-y-4', 'transition-[opacity,transform]', 'duration-500', 'ease-[var(--ease-out-expo)]');
        observer.observe(el);
    });
  </script>
</PortfolioLayout>
