---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import PortfolioLayout from '../layouts/PortfolioLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import selfImg from '../assets/images/self.jpg';
import billingDiag from '../assets/images/billing_architecture.png';
import scribeDiag from '../assets/images/clinical_scribe_architecture.png';
import astDiag from '../assets/images/ast_transformer_architecture.png';

const allPosts = await getCollection('posts');

const processedPosts = allPosts.map(post => {
  const match = post.id.match(/^(\d{4}-\d{2}-\d{2})-(.+)$/);
  const dateStr = match ? match[1] : '';
  const urlSlug = match ? match[2] : post.id;
  const dateObj = dateStr ? new Date(dateStr) : new Date();

  return {
    ...post,
    urlSlug,
    dateObj,
    formattedDate: dateObj.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      timeZone: 'UTC'
    })
  };
});

const sortedPosts = processedPosts.sort((a, b) => b.dateObj.getTime() - a.dateObj.getTime());
---

