        <div class="font-headline-md text-[24px] font-bold text-primary uppercase tracking-tighter glow-accent">Gyandeep Singh</div>
        <p class="font-technical-sm text-technical-sm text-on-surface-variant">© | Staff Software Engineer | IEEE Senior Member</p>
      </div>
      <div class="flex gap-lg">
        <a class="text-on-surface-variant font-technical-sm text-technical-sm hover:text-primary transition-colors" href="https://www.linkedin.com/in/gyandeeps" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a class="text-on-surface-variant font-technical-sm text-technical-sm hover:text-primary transition-colors" href="https://github.com/gyandeeps" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a class="text-on-surface-variant font-technical-sm text-technical-sm hover:text-primary transition-colors" href="#eminence">Patents</a>
