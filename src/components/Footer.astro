---
interface Props {
  isHome?: boolean;
}

const { isHome = false } = Astro.props;
const prefix = isHome ? "" : "/";
---

<!-- Footer -->
<footer class="w-full py-xl bg-black border-t border-primary/20">
  <div class="max-w-[1280px] mx-auto px-lg flex flex-col md:flex-row justify-between items-center gap-md">
    <div class="flex flex-col gap-2">
      <div class="font-headline-md text-[24px] font-bold text-primary uppercase tracking-tighter glow-accent">
        Gyandeep Singh
      </div>
      <p class="font-technical-sm text-technical-sm text-on-surface-variant">
        &copy; {new Date().getFullYear()} | Staff Software Engineer | IEEE Senior Member
      </p>
    </div>
    <div class="flex gap-lg">
      <a class="text-on-surface-variant font-technical-sm text-technical-sm hover:text-primary transition-colors duration-200 active-press" href="https://www.linkedin.com/in/gyandeeps" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a class="text-on-surface-variant font-technical-sm text-technical-sm hover:text-primary transition-colors duration-200 active-press" href="https://github.com/gyandeeps" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a class="text-on-surface-variant font-technical-sm text-technical-sm hover:text-primary transition-colors duration-200 active-press" href={`${prefix}#eminence`}>Patents</a>
    </div>
  </div>
</footer>
