---
interface Props {
  isHome?: boolean;
}

const { isHome = false } = Astro.props;
const prefix = isHome ? "" : "/";
---

<!-- Top Navigation Bar -->
<nav class="fixed top-0 w-full z-50 bg-black/80 backdrop-blur-md border-b border-primary/20 h-20">
  <div class="flex justify-between items-center max-w-[1280px] mx-auto px-md md:px-lg h-full">
    {isHome ? (
      <div class="font-headline-lg text-lg sm:text-headline-lg-mobile md:text-headline-lg text-primary uppercase tracking-wide md:tracking-widest flex items-center shrink-0">
        Gyandeep Singh
      </div>
    ) : (
      <a href="/" class="font-headline-lg text-lg sm:text-headline-lg-mobile md:text-headline-lg text-primary uppercase tracking-wide md:tracking-widest flex items-center hover:opacity-95 transition-opacity shrink-0 active-press">
        Gyandeep Singh
      </a>
    )}
    
    <div class="hidden md:flex gap-lg items-center">
      <a class="text-on-surface-variant font-technical-sm text-technical-sm hover:text-primary transition-colors duration-200 nav-link-active" href={`${prefix}#impact`}>Impact</a>
      <a class="text-on-surface-variant font-technical-sm text-technical-sm hover:text-primary transition-colors duration-200 nav-link-active" href={`${prefix}#experience`}>Experience</a>
      <a class="text-on-surface-variant font-technical-sm text-technical-sm hover:text-primary transition-colors duration-200 nav-link-active" href={`${prefix}#matrix`}>Architecture</a>
      <a class="text-on-surface-variant font-technical-sm text-technical-sm hover:text-primary transition-colors duration-200 nav-link-active" href={`${prefix}#lab`}>Engineering Lab</a>
      <a class="text-on-surface-variant font-technical-sm text-technical-sm hover:text-primary transition-colors duration-200 nav-link-active" href={`${prefix}#blog`}>Writing</a>
      
      <div class="flex gap-md items-center border-l border-primary/20 pl-lg ml-sm">
        <a class="text-on-surface-variant hover:text-primary transition-colors flex items-center justify-center active-press" href="https://github.com/gyandeeps" target="_blank" rel="noopener noreferrer" title="GitHub">
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.137 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z" /></svg>
        </a>
        <a class="text-on-surface-variant hover:text-primary transition-colors flex items-center justify-center active-press" href="https://www.linkedin.com/in/gyandeeps" target="_blank" rel="noopener noreferrer" title="LinkedIn">
